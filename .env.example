# =============================================================================
# StudentHV - Self-Hosting Configuration
# =============================================================================
# Copy this file to .env and customize the values for your environment.
# DO NOT commit the .env file with real secrets to version control!
#
# Quick Start:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your settings
# 3. Run: docker-compose up -d
# =============================================================================

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Domain or IP where the application will be hosted
# Example: localhost, vm.example.com, 192.168.1.100
NEXT_PUBLIC_DOMAIN=localhost

# Full URL to the API endpoint (used by the web frontend)
# Format: http(s)://<domain>/api/v1
NEXT_PUBLIC_SERVER_URL=http://localhost/api/v1

# Ports for the nginx reverse proxy
HTTP_PORT=80
HTTPS_PORT=443

# =============================================================================
# SSL / TLS CONFIGURATION
# =============================================================================

# Path to SSL certificate files (for HTTPS)
# For production, replace with paths to your real certificates
# For local testing, you can use the provided self-signed certs or use HTTP only
SSL_CERT_PATH=./nginx/fullchain.pem
SSL_KEY_PATH=./nginx/privkey.pem

# To disable HTTPS and use HTTP only, comment out the SSL lines above
# and modify nginx.conf to remove SSL configuration

# =============================================================================
# BRANDING / CUSTOMIZATION
# =============================================================================

# Application name displayed in the UI
NEXT_PUBLIC_APP_NAME=StudentHV

# URL to your logo image (should be accessible from client browsers)
# Can be a full URL (https://...) or a local path (/logo.png)
NEXT_PUBLIC_LOGO_URL=https://github.com/Stroooooo/StudentHV/raw/main/assets/logo.png

# Sidebar colors (hex format with #)
NEXT_PUBLIC_SIDEBAR_COLOR=#532E80
NEXT_PUBLIC_SIDEBAR_TEXT_COLOR=#ffffff
NEXT_PUBLIC_SIDEBAR_BORDER_COLOR=#9ca3af

# Login page background image (optional)
# Leave empty for default gradient background
NEXT_PUBLIC_LOGIN_BACKGROUND_IMAGE=

# Login card image (shown on the right side of login page)
NEXT_PUBLIC_LOGIN_CARD_IMAGE=https://images.pexels.com/photos/442150/pexels-photo-442150.jpeg

# Default email domain for users (shown in user display)
NEXT_PUBLIC_EMAIL_DOMAIN=@example.com

# Login field label (shown on login form)
# Example: "Student Number", "Username", "Email", "Employee ID"
NEXT_PUBLIC_LOGIN_FIELD_LABEL=Student Number

# =============================================================================
# SECURITY / AUTHENTICATION
# =============================================================================

# JWT Secret for signing authentication tokens
# MUST be at least 32 characters long for security
# Generate a strong random string, e.g.:
#   openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=YourVeryLongAndSecureSecretKeyForJWTSigningThatShouldBeAtLeast32Characters

# Guacamole encryption key for RDP console connections
# MUST be exactly 32 characters long
# This must match between API and guacamole-lite services
GUACAMOLE_SECRET=ThisIsA32CharacterLongSecretKey!

# CORS authorized origins (comma-separated)
# These are the URLs allowed to access the API
# Add your frontend URL here
CORS_AUTHORIZED=http://localhost:3000,http://web:3000

# =============================================================================
# ACTIVE DIRECTORY / LDAP CONFIGURATION
# =============================================================================

# LDAP server URL (without protocol)
# Example: ad.example.com or 192.168.1.10
AD_URL=

# Active Directory Distinguished Name (base DN)
# Example: DC=example,DC=com
AD_DN=

# Active Directory admin group CN
# Users in this group will have admin privileges
# Example: cn=AdminGroup
AD_ADMIN_GROUP=

# =============================================================================
# WINRM CONFIGURATION (for Hyper-V management)
# =============================================================================

# WinRM port for connecting to Hyper-V servers
# Default: 5985 (HTTP) or 5986 (HTTPS)
WINRM_PORT=5985

# =============================================================================
# HYPER-V SERVERS CONFIGURATION
# =============================================================================
# Configure one or more Hyper-V servers to manage
# Add more servers by copying and incrementing the number (SERVER3, SERVER4, etc.)

# ------------------------
# Hyper-V Server 1 (Required)
# ------------------------
SERVER1_NAME=SERVER1
SERVER1_HOST=192.168.0.10
SERVER1_USERNAME=administrator
SERVER1_PASSWORD=your_password_here
# Console credentials (optional - for RDP connections, falls back to above if not set)
SERVER1_CONSOLE_USERNAME=
SERVER1_CONSOLE_PASSWORD=

# ------------------------
# Hyper-V Server 2 (Optional)
# ------------------------
# Uncomment and set these to add a second server
# SERVER2_NAME=SERVER2
# SERVER2_HOST=192.168.0.11
# SERVER2_USERNAME=administrator
# SERVER2_PASSWORD=your_password_here
# SERVER2_CONSOLE_USERNAME=
# SERVER2_CONSOLE_PASSWORD=

# =============================================================================
# STORAGE PATHS (Host machine paths)
# =============================================================================
# These paths are mounted from the host into the API container
# They must be readable by the container

# Path to ISO files directory on host
ISO_HOST_PATH=./isos

# Path to VM configuration files on host
CONFIG_HOST_PATH=./configurations

# Path to virtual hard drives on host
HARDDRIVES_HOST_PATH=./harddrives

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================

# Async request timeout (milliseconds)
ASYNC_TIMEOUT=120000

# Tomcat connection timeout (milliseconds)
TOMCAT_CONNECTION_TIMEOUT=120000

# Maximum number of Tomcat threads
TOMCAT_MAX_THREADS=200

# Minimum spare Tomcat threads
TOMCAT_MIN_SPARE_THREADS=10

# =============================================================================
# LOGGING
# =============================================================================

# Guacamole-lite log level: DEBUG, NORMAL, or QUIET
LOG_LEVEL=NORMAL

# =============================================================================
# CONSOLE / WEBSOCKET CONFIGURATION
# =============================================================================

# Guacamole WebSocket URL (optional)
# Default: wss://<current_host>/ws/
# Only set this if you need a custom WebSocket endpoint
NEXT_PUBLIC_GUACAMOLE_WS_URL=

# =============================================================================
# AD CONFIGURATIONS
# =============================================================================
NEXT_PUBLIC_DOMAIN=vm.company.com
NEXT_PUBLIC_SERVER_URL=https://vm.company.com/api/v1
AD_URL=ad.company.com
AD_DN=DC=company,DC=com
AD_ADMIN_GROUP=cn=VM admins
SERVER1_HOST=hyperv1.company.com
SERVER1_USERNAME=svc_studenthv@company.com

NEXT_PUBLIC_SERVER_URL="http://your_url/api/v1"
NEXT_PUBLIC_DOMAIN="url_url"

# Branding
NEXT_PUBLIC_LOGO_URL="https://github.com/Stroooooo/StudentHV/raw/main/assets/logo.png"
NEXT_PUBLIC_APP_NAME="StudentHV"

# Colors (hex format)
NEXT_PUBLIC_SIDEBAR_COLOR="#532E80"
NEXT_PUBLIC_SIDEBAR_TEXT_COLOR="#ffffff"
NEXT_PUBLIC_SIDEBAR_BORDER_COLOR="#9ca3af"

# Login page
NEXT_PUBLIC_LOGIN_BACKGROUND_IMAGE="url"
NEXT_PUBLIC_LOGIN_CARD_IMAGE="https://images.pexels.com/photos/442150/pexels-photo-442150.jpeg"

# User settings
NEXT_PUBLIC_EMAIL_DOMAIN="@nescol.ac.uk"

# Console (optional, defaults to wss://<current_host>/ws/)
# NEXT_PUBLIC_GUACAMOLE_WS_URL="wss://your_domain/ws/"


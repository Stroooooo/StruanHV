FROM node:20-alpine AS deps
WORKDIR /app

# Build arguments for NEXT_PUBLIC variables (must be available at build time)
ARG NEXT_PUBLIC_SERVER_URL
ARG NEXT_PUBLIC_DOMAIN
ARG NEXT_PUBLIC_LOGO_URL
ARG NEXT_PUBLIC_APP_NAME
ARG NEXT_PUBLIC_SIDEBAR_COLOR
ARG NEXT_PUBLIC_SIDEBAR_TEXT_COLOR
ARG NEXT_PUBLIC_SIDEBAR_BORDER_COLOR
ARG NEXT_PUBLIC_LOGIN_BACKGROUND_IMAGE
ARG NEXT_PUBLIC_LOGIN_CARD_IMAGE
ARG NEXT_PUBLIC_EMAIL_DOMAIN
ARG NEXT_PUBLIC_GUACAMOLE_WS_URL
ARG NEXT_PUBLIC_LOGIN_FIELD_LABEL

COPY ./ ./
RUN rm -rf node_modules package-lock.json .next

RUN npm i
RUN npm run build

ENV NODE_ENV=production

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["npm", "run", "start"]